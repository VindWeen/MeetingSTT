# =============================================================
#  ROOT .gitignore  –  MeetingSTT (GitHub Pages + Render)
# =============================================================

# ─── Environment / Secrets ───────────────────────────────────
.env
.env.*
!.env.example        # chỉ giữ file mẫu để hướng dẫn

# ─── Node / npm ──────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
*.log

# ─── Frontend (Vite build output) ────────────────────────────
frontend/dist/
frontend/dist-ssr/
frontend/*.local

# ─── Backend – file upload tạm thời ─────────────────────────
backend/uploads/*
!backend/uploads/.gitkeep   # giữ folder rỗng trên git

# ─── OS / Editor ─────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ─── Misc ────────────────────────────────────────────────────
*.tmp
*.bak
*.orig
